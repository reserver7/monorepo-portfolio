{
  "name": "@repo/collab-server",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && mkdir -p dist && printf 'require(\"./apps/collab-server/src/index.js\");\\n' > dist/index.js",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@repo/utils": "workspace:*",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "socket.io": "^4.8.1",
    "yjs": "^13.6.27"
  },
  "devDependencies": {
    "@repo/configs": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.5",
    "jest": "^29.7.0",
    "socket.io-client": "^4.8.3",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.3"
  }
}
