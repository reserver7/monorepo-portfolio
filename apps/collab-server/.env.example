# Express + Socket.io server
PORT=4000
NODE_ENV=development

# Comma separated origins for CORS.
# Production에서는 반드시 CORS_ORIGINS를 지정하거나 ALLOW_ALL_CORS=true를 명시하세요.
CORS_ORIGINS=http://localhost:3000
ALLOW_ALL_CORS=false

# Session signing secret (production 필수)
COLLAB_SESSION_SECRET=dev-collab-session-secret

# Optional: editor 권한 승격 키 (지정 시 키 불일치 사용자는 viewer로 강등)
# EDITOR_ACCESS_KEY=change-me

# Socket hardening
SOCKET_RATE_LIMIT_WINDOW_MS=10000
SOCKET_WRITE_EVENTS_PER_WINDOW=120
SOCKET_CURSOR_EVENTS_PER_WINDOW=300
MAX_YJS_UPDATE_BASE64_CHARS=300000
MAX_SOCKET_JSON_CHARS=80000

# Persisted state file path
# 운영 환경에서는 반드시 영속 디스크 경로를 명시하세요.
# 로컬 개발에서는 미지정 시 기본값(data/state.json)을 사용합니다.
# STATE_FILE_PATH=/var/data/monorepo-portfolio/state.json
