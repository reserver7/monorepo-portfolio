{
  "name": "@repo/opslens-api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "pnpm --filter @repo/opslens-api exec prisma generate && tsc -p tsconfig.json",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "pnpm --filter @repo/opslens-api exec prisma generate && tsc -p tsconfig.json --noEmit"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@apollo/server": "^4.11.3",
    "@nestjs/apollo": "^12.2.2",
    "@nestjs/common": "^10.4.22",
    "@nestjs/core": "^10.4.22",
    "@nestjs/graphql": "^12.2.2",
    "@nestjs/platform-express": "^10.4.22",
    "@prisma/client": "^5.22.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^16.6.1",
    "graphql": "^16.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@repo/configs": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@types/node": "^22.13.5",
    "prisma": "^5.22.0",
    "tsx": "^4.20.6"
  }
}
