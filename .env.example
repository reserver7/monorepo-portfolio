# Root-level defaults used across the monorepo
NODE_ENV=development

# Optional shared API URL for local tooling/scripts
API_BASE_URL=http://localhost:4000

# OpsLens Dashboard (frontend)
NEXT_PUBLIC_API_URL=http://localhost:4100/graphql

# OpsLens API (backend)
# 런타임 연결(pooled)
DATABASE_URL=postgresql://<user>:<password>@<host>/<db>?sslmode=require&channel_binding=require
# Prisma 마이그레이션 전용 direct 연결 URL
DIRECT_DATABASE_URL=postgresql://<user>:<password>@<direct-host>/<db>?sslmode=require
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
AI_MAX_RETRIES=3
AI_RETRY_BASE_DELAY_MS=700
AI_CACHE_TTL_MS=120000
