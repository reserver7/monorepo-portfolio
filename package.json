{
  "name": "collab-suite-monorepo",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.12.3",
  "scripts": {
    "build": "pnpm turbo run build",
    "build:docs": "pnpm --filter @repo/docs build",
    "build:opslens-api": "pnpm --filter @repo/opslens-api build",
    "build:opslens-dashboard": "pnpm --filter @repo/opslens-dashboard build",
    "build:server": "pnpm --filter @repo/server build",
    "build:whiteboard": "pnpm --filter @repo/whiteboard build",
    "clean": "pnpm turbo run clean",
    "dev": "pnpm turbo run dev",
    "dev:docs": "pnpm --filter @repo/docs dev",
    "dev:opslens": "pnpm --parallel --stream --filter @repo/opslens-api --filter @repo/opslens-dashboard dev",
    "dev:opslens-api": "pnpm --filter @repo/opslens-api dev",
    "dev:opslens-dashboard": "pnpm --filter @repo/opslens-dashboard dev",
    "dev:server": "pnpm --filter @repo/server dev",
    "dev:whiteboard": "pnpm --filter @repo/whiteboard dev",
    "db:opslens:generate": "pnpm --filter @repo/opslens-api prisma:generate",
    "db:opslens:migrate:dev": "pnpm --filter @repo/opslens-api prisma:migrate:dev",
    "db:opslens:migrate:deploy": "pnpm --filter @repo/opslens-api prisma:migrate:deploy",
    "db:opslens:migrate:status": "pnpm --filter @repo/opslens-api prisma:migrate:status",
    "db:opslens:migrate:resolve": "pnpm --filter @repo/opslens-api exec prisma migrate resolve",
    "db:opslens:migrate:resolve:init": "pnpm --filter @repo/opslens-api exec prisma migrate resolve --applied 20260326000000_init",
    "db:opslens:push": "pnpm --filter @repo/opslens-api prisma:push",
    "db:opslens:studio": "pnpm --filter @repo/opslens-api prisma:studio",
    "format": "prettier --cache --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm turbo run lint",
    "lint:docs": "pnpm --filter @repo/docs lint",
    "lint:fix": "pnpm turbo run lint -- --fix",
    "lint:opslens-api": "pnpm --filter @repo/opslens-api lint",
    "lint:opslens-dashboard": "pnpm --filter @repo/opslens-dashboard lint",
    "lint:server": "pnpm --filter @repo/server lint",
    "lint:whiteboard": "pnpm --filter @repo/whiteboard lint",
    "new:app": "bash ./scripts/new-app.sh",
    "test": "pnpm turbo run test",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "typecheck": "pnpm turbo run typecheck",
    "typecheck:docs": "pnpm --filter @repo/docs typecheck",
    "typecheck:opslens-api": "pnpm --filter @repo/opslens-api typecheck",
    "typecheck:opslens-dashboard": "pnpm --filter @repo/opslens-dashboard typecheck",
    "typecheck:server": "pnpm --filter @repo/server typecheck",
    "typecheck:whiteboard": "pnpm --filter @repo/whiteboard typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@next/eslint-plugin-next": "^15.3.1",
    "@playwright/test": "^1.58.2",
    "@repo/eslint-config": "workspace:*",
    "@repo/prettier-config": "workspace:*",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.43.0"
  }
}
